# ── GUB backend ──────────────────────────────────────────────────────────────
# URL of the running GUB backend
GUB_BASE_URL=http://localhost:3000

# Service JWT for local dev / CI (no end-user OAuth).
# Generate one by logging in via the GUB frontend and copying the access token,
# or by using the broker test script: scripts/test-broker-flow.mjs
GUB_SERVICE_JWT=

# ── Gemini Enterprise OAuth ───────────────────────────────────────────────────
# The Authorization ID you registered in Gemini Enterprise under
# Agents → Authorization. Must match EXACTLY — any mismatch breaks token injection.
GUB_AUTHORIZATION_ID=gub-oauth

# ── Agent model ───────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash
AGENT_NAME=gub-agent

# ── GCP (required for deployment) ────────────────────────────────────────────
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# Populated by `adk deploy agent_engine` — paste the output here before running
# deployment/register_agent.py
AGENT_ENGINE_ID=
GEMINI_APP_ID=your-gemini-enterprise-app-id

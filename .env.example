# ── GUB backend ──────────────────────────────────────────────────────────────
# URL of the running GUB backend. NOTE: config.py's baked-in default is the
# DEV Cloud Run URL — a prod deploy MUST set this explicitly or it silently
# hits the dev backend.
GUB_BASE_URL=http://localhost:3000

# Service JWT for local dev / CI (no end-user OAuth).
# Generate one by logging in via the GUB frontend and copying the access token,
# or by using the broker test script: scripts/test-broker-flow.mjs
GUB_SERVICE_JWT=

# ── Gemini Enterprise OAuth ───────────────────────────────────────────────────
# The Authorization ID you registered in Gemini Enterprise under
# Agents → Authorization. Must match EXACTLY — any mismatch breaks token
# injection SILENTLY. Current registration is gub-oauth-3 (the -3 reflects
# re-registration during the token-injection debugging; see README Status).
GUB_AUTHORIZATION_ID=gub-oauth-3

# ── Agent model ───────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-3.5-flash
# Underscore form (config.py default). register_agent.py's displayName default
# is the dash form — set AGENT_NAME explicitly to keep them consistent.
AGENT_NAME=gub_agent

# Set to 1 to emit executor + critic thinking-token summaries in the event
# stream (for the debug client). Leave unset/0 in production.
EMIT_THINKING=0

# ── Vertex AI backend (ADK builds the model client from these) ────────────────
# gemini-3.5-flash is served ONLY from the Vertex *global* endpoint — the
# regional endpoint 404s it — so the model location must be `global`. The Agent
# Engine itself still deploys to a region (the deploy command's --region flag,
# which overrides this for the deploy target only).
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=1

# ── GCP (required for deployment) ────────────────────────────────────────────
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1

# Populated by `adk deploy agent_engine` — paste the output here before running
# deployment/register_agent.py
AGENT_ENGINE_ID=
GEMINI_APP_ID=your-gemini-enterprise-app-id
